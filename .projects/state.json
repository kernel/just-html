{
  "version": 1,
  "providers": {
    "planetscale": {
      "name": "PlanetScale"
    },
    "vercel": {
      "name": "Vercel"
    }
  },
  "resources": {
    "justhtml-db": {
      "name": "justhtml-db",
      "providerName": "PlanetScale",
      "serviceId": "postgresql"
    },
    "vercel-plan": {
      "name": "vercel-plan",
      "providerName": "Vercel",
      "serviceId": "hobby"
    }
  },
  "environments": {
    "default": {
      "output": ".env",
      "resources": [
        {
          "resourceName": "justhtml-db"
        }
      ]
    }
  }
}
