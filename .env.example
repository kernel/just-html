# justhtml.sh environment. Copy to .env and fill in. Never commit .env.

# PlanetScale Postgres (psql-compatible wire protocol)
PLANETSCALE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=verify-full
PLANETSCALE_DATABASE=postgres
PLANETSCALE_HOST=
PLANETSCALE_USERNAME=
PLANETSCALE_PASSWORD=

# Resend — login magic-link email. Sending domain: notify.justhtml.sh
RESEND_API_KEY=

# Vercel (deploy pipeline)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# QA escape hatch (B2, REMOVABLE post-launch). When set, login-link plaintext is
# stored in qa_login_links and retrievable via GET /internal/qa/latest-login-link
# (header X-QA-Secret). Leave unset in real production to disable entirely.
QA_SECRET=
